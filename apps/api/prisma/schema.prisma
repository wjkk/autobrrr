generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum ProjectContentMode {
  SINGLE
  SERIES
}

enum ProjectStatus {
  DRAFT
  PLANNING
  READY_FOR_STORYBOARD
  CREATING
  EXPORT_READY
  EXPORTED
  PUBLISHED
  FAILED
  ARCHIVED
}

enum EpisodeStatus {
  DRAFT
  PLANNING
  READY_FOR_STORYBOARD
  CREATING
  EXPORT_READY
  EXPORTED
  PUBLISHED
  ARCHIVED
}

enum PlannerStatus {
  IDLE
  UPDATING
  READY
}

enum PlannerMessageRole {
  USER
  ASSISTANT
}

enum PlannerMessageType {
  USER_INPUT
  ASSISTANT_TEXT
  ASSISTANT_OUTLINE_CARD
  ASSISTANT_STEPS
  ASSISTANT_DOCUMENT_RECEIPT
  SYSTEM_TRANSITION
}

enum PlannerOutlineStatus {
  DRAFT
  READY
  FAILED
}

enum PlannerRefinementStatus {
  DRAFT
  RUNNING
  READY
  FAILED
}

enum PlannerStepStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum ProfileReleaseStatus {
  DRAFT
  ACTIVE
  DEPRECATED
  ARCHIVED
}

enum ShotStatus {
  PENDING
  QUEUED
  GENERATING
  SUCCESS
  FAILED
}

enum ShotVersionStatus {
  PENDING_APPLY
  ACTIVE
  ARCHIVED
}

enum MediaKind {
  IMAGE
  VIDEO
}

enum AssetSourceKind {
  UPLOAD
  GENERATED
  IMPORTED
  REFERENCE
}

enum ModelKind {
  IMAGE
  VIDEO
  TEXT
  AUDIO
  LIPSYNC
}

enum ProviderType {
  OFFICIAL
  PROXY
  INTERNAL
}

enum ModelEndpointStatus {
  ACTIVE
  DISABLED
}

enum CatalogVisibility {
  PUBLIC
  PERSONAL
}

enum SubjectType {
  HUMAN
  ANIMAL
  CREATURE
  OBJECT
}

enum SubjectGenderTag {
  UNKNOWN
  FEMALE
  MALE
  CHILD
}

enum RunType {
  PLANNER_DOC_UPDATE
  STORYBOARD_GENERATION
  IMAGE_GENERATION
  VIDEO_GENERATION
  MUSIC_GENERATION
  VOICE_PROCESSING
  LIPSYNC_GENERATION
  EXPORT
  PUBLISH
  RECIPE_EXECUTION
}

enum RunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELED
  TIMED_OUT
}

enum ExecutorType {
  SYSTEM_WORKER
  PROVIDER_WORKER
  MANUAL
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique @db.VarChar(255)
  passwordHash String        @map("password_hash") @db.VarChar(255)
  displayName  String?       @map("display_name") @db.VarChar(64)
  status       UserStatus    @default(ACTIVE)
  lastLoginAt  DateTime?     @map("last_login_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  sessions     UserSession[]
  projects     Project[]
  plannerSessions PlannerSession[]
  assets       Asset[]
  providerConfigs UserProviderConfig[]
  subjectProfiles SubjectProfile[]
  stylePresets StylePreset[]
  plannerMessages PlannerMessage[]
  plannerOutlineVersions PlannerOutlineVersion[]
  plannerRefinementVersions PlannerRefinementVersion[]
  plannerDebugRuns PlannerDebugRun[]
  plannerSubAgentProfileReleases PlannerSubAgentProfileRelease[]
  externalApiCallLogs ExternalApiCallLog[]

  @@map("users")
}

model UserSession {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  sessionTokenHash String    @unique @map("session_token_hash") @db.VarChar(64)
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  lastSeenAt       DateTime? @map("last_seen_at")
  ipAddress        String?   @map("ip_address") @db.VarChar(64)
  userAgent        String?   @map("user_agent") @db.VarChar(512)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("user_sessions")
}

model Project {
  id               String             @id @default(cuid())
  title            String             @db.VarChar(255)
  brief            String?            @db.Text
  contentMode      ProjectContentMode @map("content_mode") @default(SINGLE)
  status           ProjectStatus      @default(DRAFT)
  currentEpisodeId String?            @map("current_episode_id")
  createdById      String             @map("created_by_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  archivedAt       DateTime?          @map("archived_at")
  createdBy        User               @relation(fields: [createdById], references: [id], onDelete: Restrict)
  currentEpisode   Episode?           @relation("ProjectCurrentEpisode", fields: [currentEpisodeId], references: [id], onDelete: SetNull)
  episodes         Episode[]
  plannerSessions  PlannerSession[]
  shots            Shot[]
  shotVersions     ShotVersion[]
  assets           Asset[]
  runs             Run[]
  recipes          GenerationRecipe[]
  recipeExecutions RecipeExecution[]
  creationConfig   ProjectCreationConfig?
  externalApiCallLogs ExternalApiCallLog[]

  @@index([status, updatedAt])
  @@index([createdById, updatedAt])
  @@map("projects")
}

model Episode {
  id                     String         @id @default(cuid())
  projectId              String         @map("project_id")
  episodeNo              Int            @map("episode_no")
  title                  String         @db.VarChar(255)
  summary                String?        @db.Text
  status                 EpisodeStatus  @default(DRAFT)
  activePlannerSessionId String?        @map("active_planner_session_id")
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")
  project                Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  currentForProjects     Project[]      @relation("ProjectCurrentEpisode")
  plannerSessions        PlannerSession[]
  activePlannerSession   PlannerSession? @relation("EpisodeActivePlannerSession", fields: [activePlannerSessionId], references: [id], onDelete: SetNull)
  shots                  Shot[]
  shotVersions           ShotVersion[]
  assets                 Asset[]
  runs                   Run[]
  externalApiCallLogs    ExternalApiCallLog[]

  @@unique([projectId, episodeNo])
  @@index([projectId, status, updatedAt])
  @@map("episodes")
}

model PlannerSession {
  id              String        @id @default(cuid())
  projectId       String        @map("project_id")
  episodeId       String        @map("episode_id")
  status          PlannerStatus @default(IDLE)
  isActive        Boolean       @map("is_active") @default(false)
  outlineConfirmedAt DateTime?  @map("outline_confirmed_at")
  createdById     String        @map("created_by_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  episode         Episode       @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  activeForEpisodes Episode[]   @relation("EpisodeActivePlannerSession")
  createdBy       User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  messages        PlannerMessage[]
  outlineVersions PlannerOutlineVersion[]
  refinementVersions PlannerRefinementVersion[]

  @@index([projectId, episodeId, createdAt])
  @@index([episodeId, isActive])
  @@map("planner_sessions")
}

model PlannerOutlineVersion {
  id                String               @id @default(cuid())
  plannerSessionId  String               @map("planner_session_id")
  sourceRunId       String?              @map("source_run_id")
  versionNumber     Int                  @map("version_number")
  triggerType       String               @map("trigger_type") @db.VarChar(64)
  status            PlannerOutlineStatus @default(DRAFT)
  instruction       String?              @db.Text
  assistantMessage  String?              @map("assistant_message") @db.Text
  documentTitle     String?              @map("document_title") @db.VarChar(255)
  generatedText     String?              @map("generated_text") @db.Text
  outlineDocJson    Json?                @map("outline_doc_json")
  inputSnapshotJson Json?                @map("input_snapshot_json")
  modelSnapshotJson Json?                @map("model_snapshot_json")
  operationsJson    Json?                @map("operations_json")
  isActive          Boolean              @map("is_active") @default(false)
  isConfirmed       Boolean              @map("is_confirmed") @default(false)
  confirmedAt       DateTime?            @map("confirmed_at")
  errorCode         String?              @map("error_code") @db.VarChar(120)
  errorMessage      String?              @map("error_message") @db.Text
  createdById       String?              @map("created_by_id")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  plannerSession    PlannerSession       @relation(fields: [plannerSessionId], references: [id], onDelete: Cascade)
  sourceRun         Run?                 @relation(fields: [sourceRunId], references: [id], onDelete: SetNull)
  createdBy         User?                @relation(fields: [createdById], references: [id], onDelete: SetNull)
  messages          PlannerMessage[]
  refinementVersions PlannerRefinementVersion[] @relation("OutlineToRefinements")

  @@unique([plannerSessionId, versionNumber])
  @@index([plannerSessionId, isActive, createdAt])
  @@index([sourceRunId])
  @@map("planner_outline_versions")
}

model PlannerAgentProfile {
  id                        String                   @id @default(cuid())
  slug                      String                   @unique @db.VarChar(120)
  contentType               String                   @map("content_type") @db.VarChar(64)
  displayName               String                   @map("display_name") @db.VarChar(120)
  description               String?                  @db.Text
  defaultSystemPrompt       String                   @map("default_system_prompt") @db.Text
  defaultDeveloperPrompt    String?                  @map("default_developer_prompt") @db.Text
  defaultStepDefinitionsJson Json?                   @map("default_step_definitions_json")
  defaultOutputSchemaJson   Json?                    @map("default_output_schema_json")
  defaultInputSchemaJson    Json?                    @map("default_input_schema_json")
  enabled                   Boolean                  @default(true)
  version                   Int                      @default(1)
  status                    ProfileReleaseStatus     @default(ACTIVE)
  publishedAt               DateTime?                @map("published_at")
  archivedAt                DateTime?                @map("archived_at")
  createdAt                 DateTime                 @default(now()) @map("created_at")
  updatedAt                 DateTime                 @updatedAt @map("updated_at")
  subAgentProfiles          PlannerSubAgentProfile[]
  refinementVersions        PlannerRefinementVersion[]
  debugRuns                 PlannerDebugRun[]

  @@index([contentType, enabled, updatedAt])
  @@map("planner_agent_profiles")
}

model PlannerSubAgentProfile {
  id                          String                   @id @default(cuid())
  agentProfileId              String                   @map("agent_profile_id")
  slug                        String                   @unique @db.VarChar(120)
  subtype                     String                   @db.VarChar(64)
  displayName                 String                   @map("display_name") @db.VarChar(120)
  description                 String?                  @db.Text
  systemPromptOverride        String?                  @map("system_prompt_override") @db.Text
  developerPromptOverride     String?                  @map("developer_prompt_override") @db.Text
  stepDefinitionsJson         Json?                    @map("step_definitions_json")
  outputSchemaJson            Json?                    @map("output_schema_json")
  inputSchemaJson             Json?                    @map("input_schema_json")
  toolPolicyJson              Json?                    @map("tool_policy_json")
  defaultGenerationConfigJson Json?                    @map("default_generation_config_json")
  enabled                     Boolean                  @default(true)
  version                     Int                      @default(1)
  status                      ProfileReleaseStatus     @default(ACTIVE)
  publishedAt                 DateTime?                @map("published_at")
  archivedAt                  DateTime?                @map("archived_at")
  createdAt                   DateTime                 @default(now()) @map("created_at")
  updatedAt                   DateTime                 @updatedAt @map("updated_at")
  agentProfile                PlannerAgentProfile      @relation(fields: [agentProfileId], references: [id], onDelete: Cascade)
  refinementVersions          PlannerRefinementVersion[]
  debugRuns                   PlannerDebugRun[]
  releases                    PlannerSubAgentProfileRelease[]

  @@unique([agentProfileId, subtype])
  @@index([subtype, enabled, updatedAt])
  @@map("planner_sub_agent_profiles")
}

model PlannerSubAgentProfileRelease {
  id                          String               @id @default(cuid())
  subAgentProfileId           String               @map("sub_agent_profile_id")
  releaseVersion              Int                  @map("release_version")
  displayName                 String               @map("display_name") @db.VarChar(120)
  description                 String?              @db.Text
  systemPromptOverride        String?              @map("system_prompt_override") @db.LongText
  developerPromptOverride     String?              @map("developer_prompt_override") @db.LongText
  stepDefinitionsJson         Json?                @map("step_definitions_json")
  outputSchemaJson            Json?                @map("output_schema_json")
  inputSchemaJson             Json?                @map("input_schema_json")
  toolPolicyJson              Json?                @map("tool_policy_json")
  defaultGenerationConfigJson Json?                @map("default_generation_config_json")
  publishedByUserId           String?              @map("published_by_user_id")
  publishedAt                 DateTime             @map("published_at") @default(now())
  subAgentProfile             PlannerSubAgentProfile @relation(fields: [subAgentProfileId], references: [id], onDelete: Cascade)
  publishedBy                 User?                @relation(fields: [publishedByUserId], references: [id], onDelete: SetNull)

  @@unique([subAgentProfileId, releaseVersion])
  @@index([subAgentProfileId, publishedAt])
  @@map("planner_sub_agent_profile_releases")
}

model PlannerMessage {
  id                  String                   @id @default(cuid())
  plannerSessionId    String                   @map("planner_session_id")
  outlineVersionId    String?                  @map("outline_version_id")
  refinementVersionId String?                  @map("refinement_version_id")
  role                PlannerMessageRole
  messageType         PlannerMessageType       @map("message_type")
  contentJson         Json                     @map("content_json")
  createdById         String?                  @map("created_by_id")
  createdAt           DateTime                 @default(now()) @map("created_at")
  plannerSession      PlannerSession           @relation(fields: [plannerSessionId], references: [id], onDelete: Cascade)
  outlineVersion      PlannerOutlineVersion?   @relation(fields: [outlineVersionId], references: [id], onDelete: SetNull)
  refinementVersion   PlannerRefinementVersion? @relation(fields: [refinementVersionId], references: [id], onDelete: SetNull)
  createdBy           User?                    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([plannerSessionId, createdAt])
  @@index([outlineVersionId, createdAt])
  @@index([refinementVersionId, createdAt])
  @@map("planner_messages")
}

model PlannerRefinementVersion {
  id                String                  @id @default(cuid())
  plannerSessionId  String                  @map("planner_session_id")
  agentProfileId    String?                 @map("agent_profile_id")
  subAgentProfileId String?                 @map("sub_agent_profile_id")
  sourceRunId       String?                 @map("source_run_id")
  sourceOutlineVersionId String?            @map("source_outline_version_id")
  sourceRefinementVersionId String?         @map("source_refinement_version_id")
  versionNumber     Int                     @map("version_number")
  triggerType       String                  @map("trigger_type") @db.VarChar(64)
  status            PlannerRefinementStatus @default(DRAFT)
  instruction       String?                 @db.Text
  assistantMessage  String?                 @map("assistant_message") @db.Text
  documentTitle     String?                 @map("document_title") @db.VarChar(255)
  generatedText     String?                 @map("generated_text") @db.Text
  structuredDocJson Json?                   @map("structured_doc_json")
  inputSnapshotJson Json?                   @map("input_snapshot_json")
  modelSnapshotJson Json?                   @map("model_snapshot_json")
  operationsJson    Json?                   @map("operations_json")
  isActive          Boolean                 @map("is_active") @default(false)
  isConfirmed       Boolean                 @map("is_confirmed") @default(false)
  confirmedAt       DateTime?               @map("confirmed_at")
  errorCode         String?                 @map("error_code") @db.VarChar(120)
  errorMessage      String?                 @map("error_message") @db.Text
  createdById       String?                 @map("created_by_id")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")
  plannerSession    PlannerSession          @relation(fields: [plannerSessionId], references: [id], onDelete: Cascade)
  agentProfile      PlannerAgentProfile?    @relation(fields: [agentProfileId], references: [id], onDelete: SetNull)
  subAgentProfile   PlannerSubAgentProfile? @relation(fields: [subAgentProfileId], references: [id], onDelete: SetNull)
  sourceRun         Run?                    @relation(fields: [sourceRunId], references: [id], onDelete: SetNull)
  sourceOutlineVersion PlannerOutlineVersion? @relation("OutlineToRefinements", fields: [sourceOutlineVersionId], references: [id], onDelete: SetNull)
  sourceRefinementVersion PlannerRefinementVersion? @relation("RefinementToDrafts", fields: [sourceRefinementVersionId], references: [id], onDelete: SetNull)
  draftRefinementVersions PlannerRefinementVersion[] @relation("RefinementToDrafts")
  createdBy         User?                   @relation(fields: [createdById], references: [id], onDelete: SetNull)
  messages          PlannerMessage[]
  stepAnalysis      PlannerStepAnalysis[]
  subjects          PlannerSubject[]
  scenes            PlannerScene[]
  shotScripts       PlannerShotScript[]

  @@unique([plannerSessionId, versionNumber])
  @@index([plannerSessionId, isActive, createdAt])
  @@index([sourceRunId])
  @@index([sourceOutlineVersionId])
  @@index([sourceRefinementVersionId])
  @@map("planner_refinement_versions")
}

model PlannerSubject {
  id                  String                   @id @default(cuid())
  refinementVersionId String                   @map("refinement_version_id")
  name                String                   @db.VarChar(120)
  role                String                   @db.VarChar(120)
  appearance          String                   @db.Text
  personality         String?                  @db.Text
  prompt              String                   @db.Text
  negativePrompt      String?                  @map("negative_prompt") @db.Text
  referenceAssetIdsJson Json?                  @map("reference_asset_ids_json")
  generatedAssetIdsJson Json?                  @map("generated_asset_ids_json")
  sortOrder           Int                      @map("sort_order") @default(100)
  editable            Boolean                  @default(true)
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")
  refinementVersion   PlannerRefinementVersion @relation(fields: [refinementVersionId], references: [id], onDelete: Cascade)

  @@index([refinementVersionId, sortOrder])
  @@map("planner_subjects")
}

model PlannerScene {
  id                  String                   @id @default(cuid())
  refinementVersionId String                   @map("refinement_version_id")
  name                String                   @db.VarChar(120)
  time                String                   @db.VarChar(120)
  locationType        String                   @map("location_type") @db.VarChar(32)
  description         String                   @db.Text
  prompt              String                   @db.Text
  negativePrompt      String?                  @map("negative_prompt") @db.Text
  referenceAssetIdsJson Json?                  @map("reference_asset_ids_json")
  generatedAssetIdsJson Json?                  @map("generated_asset_ids_json")
  sortOrder           Int                      @map("sort_order") @default(100)
  editable            Boolean                  @default(true)
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")
  refinementVersion   PlannerRefinementVersion @relation(fields: [refinementVersionId], references: [id], onDelete: Cascade)
  shotScripts         PlannerShotScript[]

  @@index([refinementVersionId, sortOrder])
  @@map("planner_scenes")
}

model PlannerShotScript {
  id                  String                   @id @default(cuid())
  refinementVersionId String                   @map("refinement_version_id")
  sceneId             String?                  @map("scene_id")
  actKey              String                   @map("act_key") @db.VarChar(120)
  actTitle            String                   @map("act_title") @db.VarChar(255)
  shotNo              String                   @map("shot_no") @db.VarChar(120)
  title               String                   @db.VarChar(255)
  durationSeconds     Int?                     @map("duration_seconds")
  targetModelFamilySlug String?                @map("target_model_family_slug") @db.VarChar(120)
  visualDescription   String                   @map("visual_description") @db.Text
  composition         String                   @db.Text
  cameraMotion        String                   @map("camera_motion") @db.Text
  voiceRole           String                   @map("voice_role") @db.VarChar(120)
  dialogue            String                   @db.Text
  subjectBindingsJson Json?                    @map("subject_bindings_json")
  referenceAssetIdsJson Json?                  @map("reference_asset_ids_json")
  generatedAssetIdsJson Json?                  @map("generated_asset_ids_json")
  sortOrder           Int                      @map("sort_order") @default(100)
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")
  refinementVersion   PlannerRefinementVersion @relation(fields: [refinementVersionId], references: [id], onDelete: Cascade)
  scene               PlannerScene?            @relation(fields: [sceneId], references: [id], onDelete: SetNull)

  @@index([refinementVersionId, sortOrder])
  @@index([sceneId, sortOrder])
  @@map("planner_shot_scripts")
}

model PlannerDebugRun {
  id                String                   @id @default(cuid())
  userId            String                   @map("user_id")
  agentProfileId    String?                  @map("agent_profile_id")
  subAgentProfileId String?                  @map("sub_agent_profile_id")
  compareGroupKey   String?                  @map("compare_group_key") @db.VarChar(191)
  compareLabel      String?                  @map("compare_label") @db.VarChar(16)
  executionMode     String                   @map("execution_mode") @db.VarChar(32)
  modelSnapshotJson Json?                    @map("model_snapshot_json")
  inputJson         Json?                    @map("input_json")
  finalPrompt       String                   @map("final_prompt") @db.LongText
  rawText           String?                  @map("raw_text") @db.LongText
  providerOutputJson Json?                   @map("provider_output_json")
  assistantPackageJson Json                  @map("assistant_package_json")
  errorMessage      String?                  @map("error_message") @db.Text
  createdAt         DateTime                 @default(now()) @map("created_at")
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentProfile      PlannerAgentProfile?     @relation(fields: [agentProfileId], references: [id], onDelete: SetNull)
  subAgentProfile   PlannerSubAgentProfile?  @relation(fields: [subAgentProfileId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([subAgentProfileId, createdAt])
  @@index([compareGroupKey, createdAt])
  @@map("planner_debug_runs")
}

model PlannerStepAnalysis {
  id                  String                   @id @default(cuid())
  refinementVersionId String                   @map("refinement_version_id")
  stepKey             String                   @map("step_key") @db.VarChar(120)
  title               String                   @db.VarChar(255)
  status              PlannerStepStatus        @default(PENDING)
  detailJson          Json?                    @map("detail_json")
  sortOrder           Int                      @map("sort_order") @default(100)
  createdAt           DateTime                 @default(now()) @map("created_at")
  refinementVersion   PlannerRefinementVersion @relation(fields: [refinementVersionId], references: [id], onDelete: Cascade)

  @@unique([refinementVersionId, stepKey])
  @@index([refinementVersionId, sortOrder])
  @@map("planner_step_analysis")
}

model Shot {
  id              String      @id @default(cuid())
  projectId       String      @map("project_id")
  episodeId       String      @map("episode_id")
  sequenceNo      Int         @map("sequence_no")
  title           String      @db.VarChar(255)
  subtitleText    String      @map("subtitle_text") @db.Text
  narrationText   String      @map("narration_text") @db.Text
  imagePrompt     String      @map("image_prompt") @db.Text
  motionPrompt    String      @map("motion_prompt") @db.Text
  promptJson      Json?       @map("prompt_json")
  targetVideoModelFamilySlug String? @map("target_video_model_family_slug") @db.VarChar(120)
  materialBindingsJson Json?  @map("material_bindings_json")
  plannerRefinementVersionId String? @map("planner_refinement_version_id")
  plannerShotScriptId String? @map("planner_shot_script_id")
  finalizedAt     DateTime?   @map("finalized_at")
  status          ShotStatus  @default(PENDING)
  activeVersionId String?     @map("active_version_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  episode         Episode     @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  versions        ShotVersion[] @relation("ShotVersions")
  activeVersion   ShotVersion?  @relation("ShotActiveVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)

  @@unique([episodeId, sequenceNo])
  @@index([episodeId, plannerRefinementVersionId])
  @@index([episodeId, plannerShotScriptId])
  @@map("shots")
}

model ShotVersion {
  id            String            @id @default(cuid())
  shotId        String            @map("shot_id")
  projectId     String            @map("project_id")
  episodeId     String            @map("episode_id")
  versionNumber Int               @map("version_number")
  label         String            @db.VarChar(120)
  mediaKind     MediaKind         @map("media_kind")
  status        ShotVersionStatus @default(PENDING_APPLY)
  outputAssetId String?           @map("output_asset_id")
  createdAt     DateTime          @default(now()) @map("created_at")
  shot          Shot              @relation("ShotVersions", fields: [shotId], references: [id], onDelete: Cascade)
  activeForShots Shot[]           @relation("ShotActiveVersion")
  project       Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  episode       Episode           @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  outputAsset   Asset?            @relation(fields: [outputAssetId], references: [id], onDelete: SetNull)

  @@unique([shotId, versionNumber])
  @@index([shotId, createdAt])
  @@map("shot_versions")
}

model Asset {
  id             String          @id @default(cuid())
  ownerUserId    String          @map("owner_user_id")
  projectId      String          @map("project_id")
  episodeId      String?         @map("episode_id")
  mediaKind      MediaKind       @map("media_kind")
  sourceKind     AssetSourceKind @map("source_kind")
  fileName       String          @map("file_name") @db.VarChar(255)
  mimeType       String?         @map("mime_type") @db.VarChar(120)
  fileSizeBytes  Int?            @map("file_size_bytes")
  width          Int?
  height         Int?
  durationMs     Int?            @map("duration_ms")
  storageKey     String?         @map("storage_key") @db.VarChar(255)
  sourceUrl      String?         @map("source_url") @db.VarChar(2048)
  metadataJson   Json?           @map("metadata_json")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  ownerUser      User            @relation(fields: [ownerUserId], references: [id], onDelete: Restrict)
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  episode        Episode?        @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  outputVersions ShotVersion[]

  @@index([ownerUserId, createdAt])
  @@index([projectId, episodeId, mediaKind, createdAt])
  @@map("assets")
}

model ModelFamily {
  id              String          @id @default(cuid())
  slug            String          @unique @db.VarChar(120)
  name            String          @db.VarChar(120)
  modelKind       ModelKind       @map("model_kind")
  capabilityJson  Json?           @map("capability_json")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  endpoints       ModelEndpoint[]
  runs            Run[]

  @@index([modelKind, slug])
  @@map("model_families")
}

model ModelProvider {
  id              String          @id @default(cuid())
  code            String          @unique @db.VarChar(120)
  name            String          @db.VarChar(120)
  providerType    ProviderType    @map("provider_type")
  baseUrl         String?         @map("base_url") @db.VarChar(2048)
  enabled         Boolean         @default(true)
  credentialRef   String?         @map("credential_ref") @db.VarChar(255)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  endpoints       ModelEndpoint[]
  runs            Run[]
  userConfigs     UserProviderConfig[]

  @@index([enabled, providerType])
  @@map("model_providers")
}

model UserProviderConfig {
  id              String        @id @default(cuid())
  userId          String        @map("user_id")
  providerId      String        @map("provider_id")
  apiKey          String?       @map("api_key") @db.Text
  baseUrlOverride String?       @map("base_url_override") @db.VarChar(2048)
  enabled         Boolean       @default(true)
  optionsJson     Json?         @map("options_json")
  lastTestStatus  String?       @map("last_test_status") @db.VarChar(32)
  lastTestMessage String?       @map("last_test_message") @db.Text
  lastTestAt      DateTime?     @map("last_test_at")
  lastTestEndpointSlug String?  @map("last_test_endpoint_slug") @db.VarChar(120)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        ModelProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId])
  @@index([providerId, enabled])
  @@map("user_provider_configs")
}

model ModelEndpoint {
  id                  String              @id @default(cuid())
  familyId            String              @map("family_id")
  providerId          String              @map("provider_id")
  slug                String              @unique @db.VarChar(120)
  remoteModelKey      String              @map("remote_model_key") @db.VarChar(191)
  label               String              @db.VarChar(120)
  status              ModelEndpointStatus @default(ACTIVE)
  priority            Int                 @default(100)
  isDefault           Boolean             @map("is_default") @default(false)
  costConfigJson      Json?               @map("cost_config_json")
  rateLimitConfigJson Json?               @map("rate_limit_config_json")
  defaultParamsJson   Json?               @map("default_params_json")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  family              ModelFamily         @relation(fields: [familyId], references: [id], onDelete: Cascade)
  provider            ModelProvider       @relation(fields: [providerId], references: [id], onDelete: Cascade)
  runs                Run[]
  projectCreationConfigs ProjectCreationConfig[]

  @@index([familyId, status, priority])
  @@index([providerId, status, priority])
  @@map("model_endpoints")
}

model GenerationRecipe {
  id               String              @id @default(cuid())
  projectId        String              @map("project_id")
  sourceRunId      String?             @map("source_run_id")
  name             String              @db.VarChar(255)
  recipeKind       String              @map("recipe_kind") @db.VarChar(64)
  definitionJson   Json                @map("definition_json")
  version          Int                 @default(1)
  isTemplate       Boolean             @map("is_template") @default(false)
  createdByUserId  String              @map("created_by_user_id")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  project          Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  executions       RecipeExecution[]

  @@index([projectId, createdAt])
  @@map("generation_recipes")
}

model RecipeExecution {
  id                 String      @id @default(cuid())
  recipeId           String      @map("recipe_id")
  projectId          String      @map("project_id")
  status             RunStatus   @default(QUEUED)
  inputAssetBundleJson Json?     @map("input_asset_bundle_json")
  resolvedConfigJson Json?       @map("resolved_config_json")
  outputProjectId    String?     @map("output_project_id")
  runGroupKey        String?     @map("run_group_key") @db.VarChar(191)
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  recipe             GenerationRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  project            Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([recipeId, createdAt])
  @@index([projectId, status, createdAt])
  @@map("recipe_executions")
}

model SubjectProfile {
  id                String            @id @default(cuid())
  slug              String            @unique @db.VarChar(120)
  name              String            @db.VarChar(120)
  visibility        CatalogVisibility @default(PUBLIC)
  ownerUserId       String?           @map("owner_user_id")
  subjectType       SubjectType       @map("subject_type") @default(HUMAN)
  genderTag         SubjectGenderTag  @map("gender_tag") @default(UNKNOWN)
  previewImageUrl   String            @map("preview_image_url") @db.VarChar(2048)
  referenceImageUrl String?           @map("reference_image_url") @db.VarChar(2048)
  description       String?           @db.Text
  promptTemplate    String?           @map("prompt_template") @db.Text
  negativePrompt    String?           @map("negative_prompt") @db.Text
  tagsJson          Json?             @map("tags_json")
  metadataJson      Json?             @map("metadata_json")
  enabled           Boolean           @default(true)
  sortOrder         Int               @map("sort_order") @default(100)
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  ownerUser         User?             @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  projectCreationConfigs ProjectCreationConfig[]

  @@index([visibility, enabled, sortOrder])
  @@index([ownerUserId, visibility, enabled, sortOrder])
  @@index([genderTag, enabled, sortOrder])
  @@map("subject_profiles")
}

model StylePreset {
  id              String            @id @default(cuid())
  slug            String            @unique @db.VarChar(120)
  name            String            @db.VarChar(120)
  visibility      CatalogVisibility @default(PUBLIC)
  ownerUserId     String?           @map("owner_user_id")
  previewImageUrl String            @map("preview_image_url") @db.VarChar(2048)
  description     String?           @db.Text
  promptTemplate  String?           @map("prompt_template") @db.Text
  negativePrompt  String?           @map("negative_prompt") @db.Text
  tagsJson        Json?             @map("tags_json")
  metadataJson    Json?             @map("metadata_json")
  enabled         Boolean           @default(true)
  sortOrder       Int               @map("sort_order") @default(100)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  ownerUser       User?             @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  projectCreationConfigs ProjectCreationConfig[]

  @@index([visibility, enabled, sortOrder])
  @@index([ownerUserId, visibility, enabled, sortOrder])
  @@map("style_presets")
}

model ProjectCreationConfig {
  id                   String         @id @default(cuid())
  projectId            String         @unique @map("project_id")
  selectedTab          String         @map("selected_tab") @db.VarChar(64)
  selectedSubtype      String?        @map("selected_subtype") @db.VarChar(64)
  scriptSourceName     String?        @map("script_source_name") @db.VarChar(255)
  scriptContent        String?        @map("script_content") @db.Text
  imageModelEndpointId String?        @map("image_model_endpoint_id")
  subjectProfileId     String?        @map("subject_profile_id")
  stylePresetId        String?        @map("style_preset_id")
  settingsJson         Json?          @map("settings_json")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  project              Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  imageModelEndpoint   ModelEndpoint? @relation(fields: [imageModelEndpointId], references: [id], onDelete: SetNull)
  subjectProfile       SubjectProfile? @relation(fields: [subjectProfileId], references: [id], onDelete: SetNull)
  stylePreset          StylePreset?   @relation(fields: [stylePresetId], references: [id], onDelete: SetNull)

  @@index([imageModelEndpointId])
  @@index([subjectProfileId])
  @@index([stylePresetId])
  @@map("project_creation_configs")
}

model Run {
  id               String       @id @default(cuid())
  projectId        String?      @map("project_id")
  episodeId        String?      @map("episode_id")
  modelFamilyId    String?      @map("model_family_id")
  modelProviderId  String?      @map("model_provider_id")
  modelEndpointId  String?      @map("model_endpoint_id")
  runType          RunType      @map("run_type")
  resourceType     String?      @map("resource_type") @db.VarChar(64)
  resourceId       String?      @map("resource_id") @db.VarChar(64)
  status           RunStatus    @default(QUEUED)
  executorType     ExecutorType @map("executor_type") @default(SYSTEM_WORKER)
  inputJson        Json?        @map("input_json")
  outputJson       Json?        @map("output_json")
  errorCode        String?      @map("error_code") @db.VarChar(120)
  errorMessage     String?      @map("error_message") @db.Text
  idempotencyKey   String?      @unique @map("idempotency_key") @db.VarChar(191)
  providerJobId    String?      @map("provider_job_id") @db.VarChar(191)
  providerStatus   String?      @map("provider_status") @db.VarChar(120)
  providerCallbackToken String? @map("provider_callback_token") @db.VarChar(191)
  nextPollAt       DateTime?    @map("next_poll_at")
  lastPolledAt     DateTime?    @map("last_polled_at")
  pollAttemptCount Int          @default(0) @map("poll_attempt_count")
  startedAt        DateTime?    @map("started_at")
  finishedAt       DateTime?    @map("finished_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  project          Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  episode          Episode?     @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  modelFamily      ModelFamily?   @relation(fields: [modelFamilyId], references: [id], onDelete: SetNull)
  modelProvider    ModelProvider? @relation(fields: [modelProviderId], references: [id], onDelete: SetNull)
  modelEndpoint    ModelEndpoint? @relation(fields: [modelEndpointId], references: [id], onDelete: SetNull)
  plannerOutlineVersions PlannerOutlineVersion[]
  plannerRefinementVersions PlannerRefinementVersion[]
  externalApiCallLogs ExternalApiCallLog[]

  @@index([projectId, runType, status, createdAt])
  @@index([episodeId, status, createdAt])
  @@index([modelFamilyId, modelEndpointId, createdAt])
  @@index([status, nextPollAt])
  @@map("runs")
}

model ExternalApiCallLog {
  id                String    @id @default(cuid())
  traceId           String?   @map("trace_id") @db.VarChar(191)
  runId             String?   @map("run_id")
  userId            String?   @map("user_id")
  projectId         String?   @map("project_id")
  episodeId         String?   @map("episode_id")
  resourceType      String?   @map("resource_type") @db.VarChar(64)
  resourceId        String?   @map("resource_id") @db.VarChar(191)
  modelFamilyId     String?   @map("model_family_id")
  modelProviderId   String?   @map("model_provider_id")
  modelEndpointId   String?   @map("model_endpoint_id")
  providerCode      String    @map("provider_code") @db.VarChar(120)
  capability        String    @db.VarChar(32)
  operation         String    @db.VarChar(191)
  requestUrl        String    @map("request_url") @db.VarChar(2048)
  requestMethod     String    @map("request_method") @db.VarChar(16)
  requestJson       Json?     @map("request_json")
  responseJson      Json?     @map("response_json")
  errorMessage      String?   @map("error_message") @db.Text
  providerRequestId String?   @map("provider_request_id") @db.VarChar(191)
  latencyMs         Int       @map("latency_ms")
  metadataJson      Json?     @map("metadata_json")
  createdAt         DateTime  @default(now()) @map("created_at")
  run               Run?      @relation(fields: [runId], references: [id], onDelete: SetNull)
  user              User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  project           Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  episode           Episode?  @relation(fields: [episodeId], references: [id], onDelete: SetNull)

  @@index([traceId, createdAt])
  @@index([runId, createdAt])
  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@index([providerCode, capability, createdAt])
  @@map("external_api_call_logs")
}
